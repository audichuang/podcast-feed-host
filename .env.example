# Copy to `.env` (gitignored) and fill in. Used by docker-compose.yml only.

# Host path on the NAS holding your feeds (the directory your generator writes
# into). Caddy serves $FEEDS_ROOT_HOST/feeds/<token>/... read-only.
FEEDS_ROOT_HOST=/volume1/podcasts

# Cloudflare Tunnel token: Zero Trust dashboard -> Networks -> Tunnels ->
# create a tunnel -> copy the token from the "docker" install snippet.
TUNNEL_TOKEN=
